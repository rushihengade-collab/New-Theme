<div class="kikumatsu-menu-hero-section">
  <div class="container">
    <div class="kikumatsu-menu-hero__inner">
      {% if section.settings.image != blank %}
        <div class="kikumatsu-menu-hero__image-wrapper">
          <img
            class="kikumatsu-menu-hero__image"
            src="{{ section.settings.image | image_url: width: 1920 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="1920"
            height="1080"
            loading="lazy"
          >
        </div>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="kikumatsu-menu-hero__description">
          <p>{{ section.settings.description }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .kikumatsu-menu-hero-section {
    background-image: url({{ section.settings.section_bg_image | image_url: width: 1920 }});
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    text-align: center;
  }

  .kikumatsu-menu-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .kikumatsu-menu-hero__image-wrapper {
    margin-inline:auto;
    margin-bottom: 1rem;
    max-width:450px;
    
  }

  .kikumatsu-menu-hero__image {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .kikumatsu-menu-hero__description {
    text-align: center;
  }

  .kikumatsu-menu-hero__description p {
    font-size:16px;
    margin: 0;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .kikumatsu-menu-hero-section {
      padding-top: {{ section.settings.padding-top | times: 0.9 }}px;
      padding-bottom: {{ section.settings.padding-bottom | times: 0.9 }}px;
    }

    .kikumatsu-menu-hero__image-wrapper {
      margin-bottom: 1.5rem;
    }

    .kikumatsu-menu-hero__description p {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .kikumatsu-menu-hero-section {
      padding-top: {{ section.settings.padding-top | times: 0.85 }}px;
      padding-bottom: {{ section.settings.padding-bottom | times: 0.85 }}px;
    }

    .kikumatsu-menu-hero__image-wrapper {
      margin-bottom: 1.25rem;
    }

    .kikumatsu-menu-hero__description p {
      font-size: 0.875rem;
    }
  }
</style>

{% schema %}
{
  "name": "Kikumatsu Menu Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "section_bg_image",
      "label": "Section Background Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "padding-top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Kikumatsu Menu Hero"
    }
  ]
}
{% endschema %}
