<div class="container origin-raw-materials-section">
  <div class="origin-raw-materials-container">
    {% render 'product-page-header-snippet', title: section.settings.title | default: 'Origin of raw materials' %}
    <div class="origin-raw-materials-content">
      <div class="origin-raw-materials-table-wrap">
        <table class="product-basic-info-table origin-raw-materials-table" role="table">
          <thead>
            <tr>
              <th scope="col">Main raw material</th>
              <th scope="col">Origin of raw materials</th>
            </tr>
          </thead>
          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'raw_material_row' %}
                <tr {{ block.shopify_attributes }}>
                  <td data-label="Main raw material">{{ block.settings.main_raw_material }}</td>
                  <td data-label="Origin of raw materials">{{ block.settings.origin }}</td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if section.settings.bullet_1 != blank or section.settings.bullet_2 != blank %}
        <ul class="origin-raw-materials-bullets">
          {% if section.settings.bullet_1 != blank %}
            <li>{{ section.settings.bullet_1 }}</li>
          {% endif %}
          {% if section.settings.bullet_2 != blank %}
            <li>{{ section.settings.bullet_2 }}</li>
          {% endif %}
        </ul>
      {% endif %}

      {% if section.settings.info_box_text != blank %}
        <div class="origin-raw-materials-info-box">
          <span class="origin-raw-materials-info-icon" aria-hidden="true">i</span>
          <span class="origin-raw-materials-info-text">{{ section.settings.info_box_text }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .origin-raw-materials-section {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
  }

  .origin-raw-materials-table-wrap {
    margin-bottom: 1rem;
  }

  .origin-raw-materials-table {
    width: 100% !important;
  }

  .origin-raw-materials-table th,
  .origin-raw-materials-table td {
    min-width: 0;
  }

  .origin-raw-materials-bullets {
    margin: 0 0 1rem 0;
    padding-left: 1.25rem;
    line-height: 1.6;
  }

  .origin-raw-materials-bullets li {
    margin-bottom: 0.5rem;
  }

  .origin-raw-materials-info-box {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background-color: rgb(25, 25, 113);
    color: #fff;
    padding: 0.75rem 1rem;
    border-radius: 2px;
  }

  .origin-raw-materials-info-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border: 2px solid #fff;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    font-style: italic;
  }

  .origin-raw-materials-info-text {
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .origin-raw-materials-section {
      padding-top: {{ section.settings.padding-top | times: 0.85 }}px;
      padding-bottom: {{ section.settings.padding-bottom | times: 0.85 }}px;
    }
    .origin-raw-materials-info-box {
      padding: 0.6rem 0.875rem;
    }
  }

  @media (max-width: 480px) {
    .origin-raw-materials-section {
      padding-top: {{ section.settings.padding-top | times: 0.75 }}px;
      padding-bottom: {{ section.settings.padding-bottom | times: 0.75 }}px;
    }
    .origin-raw-materials-bullets {
      padding-left: 1rem;
    }
    .origin-raw-materials-info-box {
      padding: 0.5rem 0.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Origin Raw Materials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Origin of raw materials"
    },
    {
      "type": "textarea",
      "id": "bullet_1",
      "label": "Bullet point 1",
      "default": "We have listed our representative products, focusing on those that we receive many inquiries about from customers and those that include the names of ingredients in the product name."
    },
    {
      "type": "textarea",
      "id": "bullet_2",
      "label": "Bullet point 2",
      "default": "The origin of raw materials is listed as the country of origin that may be used based on past performance or future plans at the time of the survey. Due to the time of the survey, the country of origin may not match the country of origin indicated on the product label."
    },
    {
      "type": "textarea",
      "id": "info_box_text",
      "label": "Info box text",
      "default": "Due to product renewals, etc., the contents of the product you have may differ from those on our website. Please be sure to check the product label before consuming."
    },
    {
      "type": "range",
      "id": "padding-top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "raw_material_row",
      "name": "Raw material row",
      "settings": [
        {
          "type": "text",
          "id": "main_raw_material",
          "label": "Main raw material"
        },
        {
          "type": "text",
          "id": "origin",
          "label": "Origin of raw materials"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Origin Raw Materials",
      "blocks": [
        {
          "type": "raw_material_row",
          "settings": {
            "main_raw_material": "Konjac flour",
            "origin": "Domestic"
          }
        }
      ]
    }
  ]
}
{% endschema %}
