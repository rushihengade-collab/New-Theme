<div class="container origin-raw-materials-section">
  <div class="origin-raw-materials-container">
    {% render 'product-page-header-snippet', title: section.settings.title | default: 'Origin of raw materials' %}
    <div class="origin-raw-materials-content">
      {% assign tables = product.metafields.custom.origin_of_raw_materials.value %}
      <table class="origin-raw-materials-table">
        <thead>
          <tr>
            <th>主原料</th>
            <th>原料原産地</th>
          </tr>
        </thead>
        <tbody>
          {% for table in tables.table_row.value %}
            <tr>
              <td>{{ table.origin_of_raw_materials_table_item_title }}</td>
              <td>{{ table.origin_of_raw_materials_table_item_value }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <p class="origin-raw-materials-description">
        {{ section.settings.description }}
      </p>
      <div class="origin-raw-materials-note">
        {{ section.settings.note }}
      </div>
    </div>
  </div>
</div>

<style>
  .origin-raw-materials-section {
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
  }
  .origin-raw-materials-container {
    border-top: 1px solid #dcdcdc;
    padding-top: 24px;
  }

  .origin-raw-materials-content {
    margin-top: 8px;
  }

  .origin-raw-materials-table {
    width: fit-content;
    border-collapse: collapse;
    margin-top: 12px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .origin-raw-materials-table th,
  .origin-raw-materials-table td {
    border: 1px solid #d2d2d2;
    padding: 10px 16px !important;
    text-align: left;
  }

  .origin-raw-materials-table thead th {
    background-color: #80808099;
    font-weight: 600;
  }

  .origin-raw-materials-description {
    margin: 0 0 8px;
    padding-left: 1.2em;
    font-size: 13px;
    line-height: 1.8;
    color: #333333;
  }

  .origin-raw-materials-description ul {
    margin: 0;
    padding-left: 1.2em;
  }

  .origin-raw-materials-description li {
    list-style: disc;
  }

  .origin-raw-materials-note {
    margin-top: 16px;
    padding: 10px 16px;
    background-color: #1b2c6b;
    color: #ffffff;
    font-size: 12px;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .origin-raw-materials-section {
      padding-top: {{ section.settings.padding-top | times: 0.85 }}px;
      padding-bottom: {{ section.settings.padding-bottom | times: 0.85 }}px;
    }

    .origin-raw-materials-table th,
    .origin-raw-materials-table td {
      padding: 8px 10px;
      font-size: 13px;
    }

    .origin-raw-materials-note {
      font-size: 11px;
      padding: 10px 12px;
    }

  }

  @media (max-width: 480px) {
    .origin-raw-materials-section {
      padding-top: {{ section.settings.padding-top | times: 0.75 }}px;
      padding-bottom: {{ section.settings.padding-bottom | times: 0.75 }}px;
    }

    .origin-raw-materials-table {
      font-size: 12px;
    }

    .origin-raw-materials-description {
      font-size: 12px;
      padding-left: 1em;
    }
  }
</style>

{% schema %}
{
  "name": "Origin Raw Materials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Origin of raw materials"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "richtext",
      "id": "note",
      "label": "Note"
    },
    {
      "type": "range",
      "id": "padding-top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Origin Raw Materials"
    }
  ]
}
{% endschema %}
