{% comment %}
  Extract embed URL - supports both raw URL and full iframe src
{% endcomment %}
{% assign map_url = section.settings.google_map_embed_url | strip %}
{% if map_url contains 'src="' %}
  {% assign map_url = map_url | split: 'src="' | last | split: '"' | first %}
{% elsif map_url contains "src='" %}
  {% assign map_url = map_url | split: "src='" | last | split: "'" | first %}
{% endif %}

<div class="kikumatsu-google-map-section">
  <div class="kikumatsu-google-map__wrapper">
    {% if map_url != blank %}
      <iframe
        src="{{ map_url }}"
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Google Map"
      ></iframe>
    {% else %}
      <div class="kikumatsu-google-map__placeholder">
        <p>Google Map embed URLを設定してください</p>
        <p class="kikumatsu-google-map__hint">Google Maps → 共有 → 地図を埋め込む からURLをコピーしてください</p>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .kikumatsu-google-map-section {
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  .kikumatsu-google-map__wrapper {
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    border-radius: 4px;
  }

  .kikumatsu-google-map__wrapper iframe {
    display: block;
  }

  .kikumatsu-google-map__placeholder {
    background: #f5f5f5;
    padding: 4rem 2rem;
    text-align: center;
    color: #666;
    border: 1px dashed #ccc;
    border-radius: 4px;
  }

  .kikumatsu-google-map__placeholder p {
    margin: 0 0 0.5rem 0;
  }

  .kikumatsu-google-map__hint {
    font-size: 0.875rem;
    color: #999;
  }

  @media (max-width: 768px) {
    .kikumatsu-google-map__wrapper iframe {
      height: 350px;
    }
  }

  @media (max-width: 480px) {
    .kikumatsu-google-map__wrapper iframe {
      height: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "Kikumatsu Google Map",
  "settings": [
    {
      "type": "textarea",
      "id": "google_map_embed_url",
      "label": "Google Map Embed URL",
      "info": "Google Maps → 共有 → 地図を埋め込む からURLまたはiframeコードを貼り付けてください"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Kikumatsu Google Map"
    }
  ]
}
{% endschema %}
